{
  "name": "@attest/core",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./adapters/browser/puppeteer": {
      "types": "./dist/adapters/browser/puppeteer.d.ts",
      "default": "./dist/adapters/browser/puppeteer.js"
    },
    "./adapters/model/openrouter": {
      "types": "./dist/adapters/model/openrouter.d.ts",
      "default": "./dist/adapters/model/openrouter.js"
    },
    "./adapters/resolution/dom-ladder": {
      "types": "./dist/adapters/resolution/dom-ladder.d.ts",
      "default": "./dist/adapters/resolution/dom-ladder.js"
    },
    "./adapters/storage/disk": {
      "types": "./dist/adapters/storage/disk.d.ts",
      "default": "./dist/adapters/storage/disk.js"
    },
    "./adapters/storage/s3": {
      "types": "./dist/adapters/storage/s3.d.ts",
      "default": "./dist/adapters/storage/s3.js"
    },
    "./adapters/storage/user-assets-disk": {
      "types": "./dist/adapters/storage/user-assets-disk.d.ts",
      "default": "./dist/adapters/storage/user-assets-disk.js"
    },
    "./adapters/storage/user-assets-s3": {
      "types": "./dist/adapters/storage/user-assets-s3.d.ts",
      "default": "./dist/adapters/storage/user-assets-s3.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@attest/contracts": "workspace:*",
    "@aws-sdk/client-s3": "^3.1073.0",
    "nanoid": "^5.1.15",
    "openai": "^6.44.0",
    "puppeteer": "^25.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0"
  }
}
