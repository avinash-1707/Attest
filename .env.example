# Build selector: "oss" (packages + apps, ee absent) or "hosted" (adds ee/) [tech-arch §1.4]
ATTEST_BUILD=oss

# Postgres (packages/db, Drizzle) [tech-arch Tech stack]
DATABASE_URL=postgres://attest:attest@localhost:5432/attest

# Redis / BullMQ queue [arch §12]
REDIS_URL=redis://localhost:6379

# Secret encryption: base64-encoded 32-byte KEK behind the swappable KeyProvider [tech-arch §6.2].
# Required; the backend + worker fail closed at boot if absent or not 32 bytes.
ATTEST_KEK=
# Optional KEK identifier stamped on wrapped DEKs (defaults to "env"); bump when rotating the KEK.
ATTEST_KEK_ID=env

# Auth (BetterAuth) [arch §6.1]
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# CORS + CSRF allowlist for the cookie session path. Must include every browser origin that talks to
# the backend: apps/web (auth surface) and apps/dashboard (the app). Comma-separated, fail-closed.
TRUSTED_ORIGINS=http://localhost:3002,http://localhost:3001
# Google OAuth (optional; social sign-in is enabled only when both are set) [arch §6.1]
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Cross-subdomain SSO: the parent domain the session cookie is scoped to, so web (root domain) and
# dashboard (app. subdomain) share one session [arch §3.1]. Prod: set to the shared parent, e.g.
# ".attest.io". LOCAL: leave UNSET - localhost has no shared parent, so the cookie stays host-only and
# flows across the :3000/:3001/:3002 ports as-is. Requires BETTER_AUTH_URL to be https in prod.
COOKIE_DOMAIN=

# Frontend public URLs (NEXT_PUBLIC_*, inlined at build, no secrets) [arch §3.1, §3.2]
# web (auth/landing) on :3002, dashboard (app) on :3001, both pointing at the backend on :3000.
# Prod: web on the root domain, dashboard on the app. subdomain; set COOKIE_DOMAIN (above) for SSO.
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_WEB_URL=http://localhost:3002
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001

# Models: OpenRouter gateway (hosted default key) [tech-arch §3.3]
OPENROUTER_API_KEY=

# Evidence store [arch §9]: "disk" (self-hosted, default) or "s3" (S3-protocol, R2-compatible).
EVIDENCE_BACKEND=disk
# disk backend: filesystem root the worker writes to and the backend reads from.
EVIDENCE_ROOT=/var/lib/attest/evidence
# s3 backend (set EVIDENCE_BACKEND=s3): bucket + the S3-protocol endpoint (R2 = https://<acct>.r2.cloudflarestorage.com).
# endpoint/region/keys are optional when the runtime supplies them (e.g. instance role).
EVIDENCE_BUCKET=
EVIDENCE_ENDPOINT=
EVIDENCE_REGION=
EVIDENCE_ACCESS_KEY_ID=
EVIDENCE_SECRET_ACCESS_KEY=

# Billing + metering (ee/, hosted only) [tech-arch §13]. OFF by default: the OSS build never meters,
# never gates, runs unlimited. Set BILLING_ENABLED=true on hosted to turn on the credit gate + meter.
# REQUIRE_BILLING=true makes boot fail closed if @attest/ee or DODO_WEBHOOK_KEY is missing (never run
# a hosted box silently free). Both the backend and the worker read these.
BILLING_ENABLED=false
REQUIRE_BILLING=false
# Dodo Payments (Merchant of Record) [tech-arch §13.5, §13.6]. Never logged.
# - DODO_WEBHOOK_KEY: Standard-Webhooks signing key, verifies inbound /webhooks/dodo (credit grants).
# - DODO_PAYMENTS_API_KEY: API bearer token for OUTBOUND calls (self-serve checkout + customer portal).
# - DODO_ENVIRONMENT: test_mode (dev/staging) | live_mode (prod). Defaults to test_mode.
# - DASHBOARD_URL: where Dodo redirects back after checkout / from the portal (the dashboard origin).
DODO_WEBHOOK_KEY=
DODO_PAYMENTS_API_KEY=
DODO_ENVIRONMENT=test_mode
DASHBOARD_URL=http://localhost:3001
# Dodo product ids that map a subscription/pack to a plan [tech-arch §13.3]. Set from the Dodo dashboard.
# Team/Business are the two subscription plans (base credits per ee/billing/plans.ts); Pack is PAYG top-up.
DODO_PRODUCT_TEAM=
DODO_PRODUCT_BUSINESS=
DODO_PRODUCT_PACK=
