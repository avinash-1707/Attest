# Build selector: "oss" (packages + apps, ee absent) or "hosted" (adds ee/) [tech-arch §1.4]
ATTEST_BUILD=oss

# Postgres (packages/db, Drizzle) [tech-arch Tech stack]
DATABASE_URL=postgres://attest:attest@localhost:5432/attest

# Redis / BullMQ queue [arch §12]
REDIS_URL=redis://localhost:6379

# Secret encryption: base64 KEK behind the swappable KeyProvider [tech-arch §6.2]
ATTEST_KEK_BASE64=

# Auth (BetterAuth) [arch §6.1]
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Models: OpenRouter gateway (hosted default key) [tech-arch §3.3]
OPENROUTER_API_KEY=

# Evidence store: Cloudflare R2 (hosted) / local disk (self-hosted) [arch §9]
EVIDENCE_STORE=disk
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Payments (ee/, hosted only) Dodo Payments [tech-arch §13.5]
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_SECRET=
